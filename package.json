{
  "name": "horarios-ifmt-cba",
  "private": true,
  "workspaces": [
    "shared",
    "scraper",
    "web"
  ],
  "scripts": {
    "dev": "npm run dev -w web -- --open --host",
    "scrape": "npm run scrape -w scraper",
    "typecheck": "tsc --noEmit -p scraper && tsc --noEmit -p web && tsc --noEmit -p shared",
    "test": "vitest run",
    "validate:commit": "bash scripts/validate-commit-msg.sh",
    "postinstall": "bash scripts/setup-githooks.sh"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
